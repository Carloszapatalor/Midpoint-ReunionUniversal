# Turso Database Configuration
# Obtén estos valores desde: https://turso.tech/app
TURSO_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-token-here

# Recuperacion por email (opcional)
# Si RESEND_API_KEY esta vacio el servidor solo logueara el link a consola.
RESEND_API_KEY=
RECOVERY_FROM_EMAIL=Reunion Universal <onboarding@resend.dev>
APP_BASE_URL=http://localhost:8000
